{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/nvapi/:path*", "destination": "https://integrate.api.nvidia.com/:path*" },
    { "source": "/zai/:path*", "destination": "https://api.z.ai/:path*" },
    { "source": "/ddg/:path*", "destination": "https://api.duckduckgo.com/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ]
}
